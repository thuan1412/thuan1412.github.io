#!/usr/bin/env bash

set -e

# Check Ruby is available
if ! command -v ruby &> /dev/null; then
  echo "Error: Ruby is not installed. Please install Ruby 3.x first."
  exit 1
fi

RUBY_VER=$(ruby -e 'puts RUBY_VERSION')
echo "==> Using Ruby $RUBY_VER"

# Ensure a recent bundler is available
BUNDLER_VER=$(bundle --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
BUNDLER_MAJOR=${BUNDLER_VER%%.*}
BUNDLER_MINOR=${BUNDLER_VER##*.}
if [ "$BUNDLER_MAJOR" -lt 2 ] || { [ "$BUNDLER_MAJOR" -eq 2 ] && [ "$BUNDLER_MINOR" -lt 4 ]; }; then
  echo "==> Bundler $BUNDLER_VER is outdated, installing a newer version..."
  gem install bundler
fi

echo "==> Running \`bundle install\`"
bundle install
echo "==> Done! Run bin/start to launch the dev server."
